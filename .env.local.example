# Copie para .env.local e preencha. NUNCA comite .env.local.

# Senha única do time (a que todos digitam para entrar)
TEAM_PASSWORD=troque-esta-senha

# Segredo para assinar o cookie de sessão. Gere um valor aleatório longo, ex:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=troque-por-um-valor-aleatorio-longo

# Supabase — Project Settings > API
# URL do projeto (algo como https://xxxx.supabase.co)
SUPABASE_URL=
# service_role key (SECRETA — só no servidor, nunca no navegador)
SUPABASE_SERVICE_ROLE_KEY=
